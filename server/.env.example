# --- DB ---
DATABASE_URL=postgresql://kote:kote_dev_pw@localhost:5432/kote

# --- API server ---
APP_HOST=127.0.0.1
APP_PORT=8000

# --- Re-ID matching ---
# 코사인 유사도 임계값. 0.85 이상이면 동일인 후보로 판정.
REID_SIMILARITY_THRESHOLD=0.85
# OSNet 임베딩 차원 (팀장님과 합의 후 변경 가능: 512 또는 1024)
EMBEDDING_DIM=512

# --- AI Token Governor (10단계에서 사용) ---
DAILY_TOKEN_BUDGET=100000
PER_REQUEST_MAX_TOKENS=2000

