# EYE-D 백엔드 (PS Center 운영자 제품의 코어) 환경변수 템플릿
# 이 파일을 복사해서 .env 로 만든 뒤 본인 환경에 맞게 수정합니다.

# --- DB ---
# kote → eyed 네이밍 통일 (2026-05-19) + docker-compose 정합 위해 호스트 포트 5433
DATABASE_URL=postgresql://eyed:eyed_dev_pw@localhost:5433/eyed

# --- API server ---
APP_HOST=127.0.0.1
APP_PORT=8000

# --- Re-ID matching ---
# 코사인 유사도 임계값. 이 값 이상이면 동일인 후보로 판정.
REID_SIMILARITY_THRESHOLD=0.85
# OSNet 임베딩 차원 (팀장님과 합의 후 변경 가능: 512 또는 1024)
EMBEDDING_DIM=512

# --- Smart Retail: 고객 분류 ---
# 단골(regular) 자동 승격 기준 방문 횟수
REGULAR_VISIT_THRESHOLD=5
# 한 사람의 "재방문"으로 인정하는 최소 간격(초). 같은 사람이 카메라에 잠깐 사라졌다 다시 보이는 경우를 한 번으로 묶음.
REVISIT_GAP_SECONDS=900
# 동일 zone 안에서 1번 방문으로 묶는 최대 공백(초)
ZONE_VISIT_GAP_SECONDS=30

# --- AI Token Governor (확장 단계) ---
DAILY_TOKEN_BUDGET=100000
PER_REQUEST_MAX_TOKENS=2000

# OPENAI_API_KEY=sk-...
